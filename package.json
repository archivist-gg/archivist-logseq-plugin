{
  "name": "logseq-plugin-archivist",
  "version": "0.7.0",
  "description": "D&D 5e stat blocks, spells, and magic items for Logseq",
  "main": "dist/index.html",
  "logseq": {
    "id": "archivist-ttrpg",
    "title": "Archivist TTRPG Blocks",
    "icon": "icon.png"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:sidecar": "cd sidecar && npm run build",
    "build:all": "npm run build && npm run build:sidecar",
    "test:all": "npm run test && cd sidecar && npm run test"
  },
  "dependencies": {
    "@logseq/libs": "^0.0.17",
    "cannon-es": "^0.20.0",
    "js-yaml": "^4.1.0",
    "markdown-it": "^14.1.1",
    "moo": "^0.5.3",
    "three": "^0.183.2"
  },
  "overrides": {
    "dompurify": "^3.4.0",
    "lodash-es": "^4.17.24"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/moo": "^0.5.10",
    "@types/three": "^0.183.1",
    "jsdom": "^29.0.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-logseq": "^1.1.2",
    "vitest": "^3.0.0"
  }
}
