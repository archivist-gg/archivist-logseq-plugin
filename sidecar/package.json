{
  "name": "archivist-bridge",
  "version": "0.7.0",
  "type": "module",
  "description": "Local AI server that connects Archivist TTRPG plugins to Archivist Inquiry, a D&D 5e chat assistant powered by Claude",
  "main": "dist/cli.js",
  "bin": {
    "archivist-bridge": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && cp -r src/ai/srd/data dist/ai/srd/data",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.0",
    "js-yaml": "^4.1.1",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/js-yaml": "^4.0.9",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "dnd",
    "5e",
    "ttrpg",
    "claude",
    "ai",
    "logseq",
    "obsidian",
    "archivist"
  ],
  "license": "AGPL-3.0"
}
